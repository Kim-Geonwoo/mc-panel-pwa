# mc_sv-panel — 백엔드(api/) 환경변수.
# 로컬 개발용으로 `.env`에 복사하거나 런처(systemd, Docker…)에서 설정한다.
# 모든 값에 안전한 기본값이 있으며, 여기엔 비밀 정보가 없다.

# --- HTTP ---
# 패널(API + 정적 사이트)의 바인드 주소. 리버스 프록시/터널 뒤에서는 127.0.0.1:8080,
# 모든 인터페이스에서 수신하려면 ":8080".
PANEL_LISTEN=127.0.0.1:8080
# /healthz와 봇 전용 내부 API(/internal/*)를 서빙하는 별도 리스너 — 반드시 루프백 유지.
PANEL_HEALTH_LISTEN=127.0.0.1:8099
# 출처 분리 로컬 개발용 CORS allow-origin(예: http://localhost:3000).
# 프로덕션에서는 비워둔다(동일 출처: Go가 정적 사이트와 API를 함께 서빙).
PANEL_ALLOW_ORIGIN=

# --- 데이터 소스 ---
# 동반 디스코드 봇이 JSON을 기록하는 디렉터리
# (records/auth/sessions/chat/web_revoked/web_outbox).
PANEL_BRIDGE_DIR=./data
# 서버 측 KubeJS 스크립트가 status/perf JSON을 기록하는 디렉터리.
PANEL_MC_DATA_DIR=./data
# 빌드된 정적 사이트 디렉터리(Next.js `output: export` -> web/out).
PANEL_STATIC_DIR=./web/out
# 채팅·타임라인 SQLite DB 경로(기본: <PANEL_BRIDGE_DIR>/panel.db).
# PANEL_DB=./data/panel.db
# 웹→게임 전달 큐(KubeJS 소비, 기본 <PANEL_MC_DATA_DIR>/web_to_game.json).
# PANEL_GAME_INBOX=./data/web_to_game.json
# 세부 오버라이드(선택 — 기본은 위 디렉터리):
# PANEL_TIMELINE_JSON=./data/timeline.json
# PANEL_STATUS_JSON=./data/status.json
# PANEL_PERF_JSON=./data/perf.json
# PANEL_PERF_HISTORY_JSON=./data/perf_history.json
# PANEL_RECORDS_JSON=./data/records.json
# PANEL_AUTH_JSON=./data/auth.json
# PANEL_SESSIONS_JSON=./data/sessions.json
# PANEL_CHAT_JSON=./data/chat.json
# PANEL_REVOKED_JSON=./data/web_revoked.json
# PANEL_OUTBOX_DIR=./data/web_outbox

# --- 동작 ---
PANEL_MAX_PLAYERS=20
PANEL_FRESH_SEC=21
PANEL_SESSION_SEC=172800
# 타임라인 접속 이벤트 보존 일수(DB에서 매시간 정리).
PANEL_TIMELINE_RETENTION_DAYS=90
# 6자리 로그인 코드 로테이션 주기(초, 기본 6시간) — 코드는 API가 생성·기록한다.
PANEL_CODE_ROTATE_SEC=21600

# --- 보안·알림 ---
# 로그인 실패 급증·전역 리미터 포화 경보를 받을 디스코드 웹훅 URL(비우면 로그만).
# PANEL_ALERT_WEBHOOK=

# --- 데모 모드 ---
# true면 패널이 모든 브리지 파일을 무시하고 내장 샘플 데이터를 서빙하므로,
# 봇/게임 서버 없이 독립 실행된다. 데모 모드 로그인 코드: 000000.
PANEL_DEMO=false
